# DNS Control — Backend Environment Variables
# Copy to /etc/dns-control/env or export before starting the server.

DNS_CONTROL_DB_PATH=./dns-control.db
DNS_CONTROL_SECRET_KEY=CHANGE_ME_run_openssl_rand_hex_32
DNS_CONTROL_SESSION_TIMEOUT_MINUTES=30
DNS_CONTROL_SESSION_WARNING_SECONDS=120
DNS_CONTROL_INITIAL_ADMIN_USERNAME=admin
DNS_CONTROL_INITIAL_ADMIN_PASSWORD=admin
DNS_CONTROL_HOST=127.0.0.1
DNS_CONTROL_PORT=8000
