# DNS Control — Sudoers policy (diagnostics + deploy)
# Install: sudo cp this-file /etc/sudoers.d/dns-control-diagnostics
# Validate: sudo visudo -cf /etc/sudoers.d/dns-control-diagnostics
#
# Grants the dns-control service user NOPASSWD access to:
# 1. Diagnostic commands (read-only, per-instance targeting)
# 2. Deploy commands (file install, service restart, sysctl)

# Change "dns-control" below to match the actual service user
Defaults:dns-control !requiretty

dns-control ALL=(root) NOPASSWD: \
    /usr/sbin/unbound-control -s *, \
    /usr/sbin/unbound-control stats_noreset, \
    /usr/sbin/unbound-control status, \
    /usr/sbin/unbound-control dump_cache, \
    /usr/sbin/nft list tables, \
    /usr/sbin/nft list ruleset, \
    /usr/sbin/nft list counters, \
    /usr/sbin/nft -c -f *, \
    /usr/sbin/nft -f *, \
    /usr/bin/vtysh -c *, \
    /usr/bin/journalctl --no-pager *, \
    /usr/bin/install -m * -o * -g * *, \
    /usr/bin/install -m *, \
    /usr/bin/cp --no-preserve=ownership *, \
    /usr/bin/chmod *, \
    /usr/bin/mkdir -p *, \
    /usr/bin/systemctl daemon-reload, \
    /usr/bin/systemctl restart unbound*, \
    /usr/bin/systemctl restart frr, \
    /usr/bin/systemctl restart nftables, \
    /usr/bin/systemctl restart nginx, \
    /usr/bin/systemctl start nftables, \
    /usr/bin/systemctl start nginx, \
    /usr/bin/systemctl enable unbound*, \
    /usr/bin/systemctl enable frr, \
    /usr/bin/systemctl enable nftables, \
    /usr/bin/systemctl enable nginx, \
    /usr/bin/systemctl disable unbound*, \
    /usr/bin/systemctl disable systemd-resolved, \
    /usr/bin/systemctl stop systemd-resolved, \
    /usr/bin/systemctl mask unbound.service, \
    /usr/bin/systemctl status unbound*, \
    /usr/bin/systemctl status frr, \
    /usr/bin/systemctl status nftables, \
    /usr/bin/systemctl status nginx, \
    /usr/bin/systemctl status networking, \
    /usr/bin/systemctl is-active nftables, \
    /usr/bin/systemctl is-active frr, \
    /usr/bin/systemctl is-active nginx, \
    /usr/bin/systemctl is-active networking, \
    /usr/bin/systemctl is-active unbound*, \
    /usr/bin/systemctl is-enabled unbound*, \
    /usr/bin/systemctl is-enabled frr, \
    /usr/bin/systemctl is-enabled nftables, \
    /usr/bin/systemctl is-enabled nginx, \
    /usr/bin/systemctl is-enabled networking, \
    /usr/bin/systemctl list-units --type=service *, \
    /usr/sbin/sysctl --load *, \
    /usr/sbin/ifreload -a, \
    /usr/bin/killall -q unbound, \
    /usr/sbin/nft flush ruleset, \
    /usr/sbin/ip addr *, \
    /usr/sbin/ip -6 addr *, \
    /usr/bin/bash -n *, \
    /etc/network/post-up.d/dns-control
